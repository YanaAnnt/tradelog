# Copy this to .env.local and fill in real values from your Supabase project

# --- Public (safe to ship to the browser) ---
# Supabase: Settings -> API -> Project URL and "anon public" key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The public URL of this app (use http://localhost:3000 in dev, your Vercel URL in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Server-only (NEVER expose to the browser) ---
# Supabase: Settings -> API -> "service_role" key (bypasses Row Level Security).
# Required by the cron sync route to read everyone's broker connections.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Random long string. Vercel sends this in the Authorization header on every cron run.
# Generate: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string
